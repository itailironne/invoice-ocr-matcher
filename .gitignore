# =============================================================================
# Sensitive data — NEVER commit these
# =============================================================================
# Anthropic API key (set as env var; never put in code)
.env
.env.*
*.env
ANTHROPIC_API_KEY

# Real customer / financial PDFs — these may contain sensitive business data
*.pdf
!samples/example_*.pdf

# Real customer receipt photos / scans
*.jpg
*.jpeg
*.png
*.webp
*.heic
*.tif
*.tiff
*.bmp
!samples/example_*.jpg
!samples/example_*.png

# Generated job folders (contain processed user data)
web_outputs/
full_run_output/

# Real customer CSVs
*.csv
!samples/example_*.csv

# CFO / private photos
static/cfo.jpg
static/*.jpg
static/*.jpeg
static/*.png
!static/logo.svg
!static/.gitkeep

